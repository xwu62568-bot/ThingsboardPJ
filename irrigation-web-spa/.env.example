# ============================================================
# 前端运行配置
# 说明：VITE_* 会被打包进前端。GitHub Pages / Vite 构建时也需要这些变量。
# ============================================================

# ThingsBoard 默认地址。
# 用在登录页默认平台地址；用户仍可在登录页手动切换。
VITE_TB_BASE_URL=http://58.210.46.6:8888

# 高德地图配置。
# 用在地块地图、总览地图。没有这两个值时，真实地图无法加载。
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# 地块巡检 Scheduler 配置。
# 用在前端创建地块时：每个地块创建 1 个 fieldInspect 巡检 Scheduler。
VITE_TB_FIELD_SCHEDULER_EVENT_TYPE=IRRIGATION_PLAN_TICK
VITE_TB_FIELD_SCHEDULER_EVENT_PREFIX=专业灌溉巡检：
VITE_TB_FIELD_SCHEDULER_TIMEZONE=Asia/Shanghai
VITE_TB_FIELD_SCHEDULER_PERIOD_SECONDS=60

# 灌溉计划 Scheduler 配置。
# 用在前端保存自动执行计划时：每个自动计划创建 1 个 planSchedule Scheduler。
VITE_TB_PLAN_SCHEDULER_EVENT_PREFIX=专业灌溉计划：

# 设备映射，可选。
# 用在 ThingsBoard 设备信息不足时，补充站点数、RPC 网关名等能力。
# VITE_TB_DEVICE_MAPPINGS=[{"name":"WC310BL","rpcGatewayName":"ble网关","siteCount":8}]


# ============================================================
# 规则链初始化脚本配置
# 说明：下面变量只给 `npm run tb:setup-rule-chain` / `node scripts/setup-irrigation-rule-chain.mjs` 使用。
# 前端页面运行不需要 TB_USERNAME / TB_PASSWORD。
# ============================================================

# ThingsBoard 登录信息。
# TB_BASE_URL 不填时，脚本会复用 VITE_TB_BASE_URL。
TB_BASE_URL=http://58.210.46.6:8888
TB_USERNAME=tenant@example.com
TB_PASSWORD=

# 规则链名称。
# 脚本会创建或更新这个规则链。
TB_RULE_CHAIN_NAME=专业灌溉执行链

# 是否自动更新 Root Rule Chain 转发。
# 用途：把 fieldInspect / planSchedule / 手动执行消息转发到专业灌溉执行链。
TB_UPDATE_ROOT_RULE_CHAIN=1

# 规则链触发模式。
# scheduler：推荐，使用 ThingsBoard Scheduler。
# generator：仅用于本地 CE 兜底，会在规则链里创建 Generator 节点。
TB_TRIGGER_MODE=scheduler

# 脚本批量创建“地块巡检 Scheduler”时使用。
# 这组含义和前端 VITE_TB_FIELD_SCHEDULER_* 对应，但只影响脚本创建的 Scheduler。
# 如果 Scheduler 主要由前端创建，可以不配置这组，使用默认值即可。
TB_TICK_PERIOD_SECONDS=60
TB_SCHEDULER_EVENT_TYPE=IRRIGATION_PLAN_TICK
TB_SCHEDULER_EVENT_PREFIX=专业灌溉巡检：
TB_SCHEDULER_TIMEZONE=Asia/Shanghai

# 可选：只处理指定 Field 资产。
# 不填表示处理全部 Field。多个 ID 用英文逗号分隔。
# TB_FIELD_ASSET_IDS=

# 可选：使用 ThingsBoard 导出的规则链 metadata JSON。
# 只有默认规则链 metadata 不兼容当前 TB 版本时才需要。
# TB_RULE_CHAIN_METADATA=./rule-chain-metadata.json

# 可选：只打印将要写入的内容，不真正写入 ThingsBoard。
# TB_RULE_CHAIN_DRY_RUN=1

# 可选：规则链节点 Debug。
# 默认脚本会打开关键排障节点的 Debug。需要全部节点开启时设置为 1。
# TB_DEBUG_ALL_NODES=1
# TB_DEBUG_NODE_NAMES=生成基础轮灌命令,存在待执行命令,准备设备 RPC,下发开阀命令,未执行原因
#cd irrigation-web-spa
#node scripts/setup-irrigation-rule-chain.mjs
